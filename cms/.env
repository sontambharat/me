# --- Database -------------------------------------------------------------
# SQLite for local/sandbox. For production change the provider in
# prisma/schema.prisma to "postgresql" and point this at your Postgres server.
DATABASE_URL="file:./dev.db"

# --- Auth -----------------------------------------------------------------
AUTH_SECRET="dev-secret-change-me-in-production"

# --- Media storage --------------------------------------------------------
# When AZURE_STORAGE_CONNECTION_STRING is set, uploads go to Azure Blob
# Storage. Otherwise the app falls back to local disk (./storage) so it runs
# in the sandbox with no cloud credentials.
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="cms-media"
