// Multi-Site CMS data model.
//
// Provider is SQLite for local/sandbox. To run on PostgreSQL in production,
// change `provider` to "postgresql" and point DATABASE_URL at your server —
// the schema is written to port cleanly (no SQLite-only features). Structured
// fields are stored as JSON strings so the model is identical on both engines;
// switch them to `Json`/`jsonb` when moving to Postgres if you want querying.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  roles        UserRole[]
  sessions     Session[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model UserRole {
  id     String  @id @default(cuid())
  role   String // super_admin | site_admin | editor | reviewer | guest_reviewer
  siteId String? // null for super_admin (global)
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([siteId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Site {
  id        String       @id @default(cuid())
  name      String
  key       String       @unique
  theme     String       @default("{}") // JSON: { accent, font, logoUrl, pageBg, radius }
  templates Template[]
  pages     Page[]
  assets    Asset[]
  nav       Navigation?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Template {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  slots     String   @default("[]") // JSON string[]
  schema    String   @default("{}") // JSON { slot: { allowedWidgetTypes, required } }
  version   Int      @default(1)
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WidgetDef {
  id         String   @id @default(cuid())
  siteId     String? // null = global / cross-site
  name       String
  type       String
  schema     String   @default("{}") // JSON field definitions
  renderer   String
  category   String   @default("general")
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([siteId])
}

model SharedContent {
  id        String   @id @default(cuid())
  siteId    String? // null = global
  key       String
  type      String   @default("richtext")
  data      String   @default("{}") // JSON
  revision  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}

model Asset {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  mimeType   String
  size       Int
  storageKey String // blob path (Azure) or local file key
  width      Int?
  height     Int?
  alt        String   @default("")
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([siteId])
}

model Navigation {
  id        String   @id @default(cuid())
  siteId    String   @unique
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  items     String   @default("[]") // JSON tree: [{ id, label, url, children: [] }]
  updatedAt DateTime @updatedAt
}

model Page {
  id               String        @id @default(cuid())
  siteId           String
  site             Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  templateId       String
  template         Template      @relation(fields: [templateId], references: [id])
  title            String
  slug             String
  state            String        @default("draft") // draft|in_review|approved|published|archived
  currentVersionId String?
  versions         PageVersion[]
  previewLinks     PreviewLink[]
  comments         Comment[]
  reviews          ReviewRequest[]
  createdBy        String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([siteId, slug])
}

model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  siteId    String
  version   Int
  title     String
  slug      String
  metadata  String   @default("{}") // JSON
  content   String   @default("{}") // JSON { slots: { name: [instances] } }
  note      String?
  createdBy String
  createdAt DateTime @default(now())

  @@index([pageId])
}

model PreviewLink {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  siteId    String
  versionId String
  token     String   @unique
  scope     String   @default("page")
  expiresAt DateTime?
  revoked   Boolean  @default(false)
  views     String   @default("[]") // JSON
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  siteId      String
  parentId    String?
  pin         String? // JSON { x, y, selector }
  body        String
  authorId    String?
  authorName  String
  visibility  String   @default("internal")
  state       String? // open|in_progress|resolved (null on replies)
  reactions   String   @default("[]") // JSON
  attachments String   @default("[]") // JSON
  stale       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageId])
}

model ReviewRequest {
  id                  String   @id @default(cuid())
  pageId              String
  page                Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  siteId              String
  reviewerIds         String   @default("[]") // JSON
  requiredReviewerIds String   @default("[]") // JSON
  dueDate             DateTime?
  status              String   @default("pending")
  decisions           String   @default("[]") // JSON
  createdBy           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([pageId])
}

model FormSubmission {
  id         String   @id @default(cuid())
  siteId     String
  pageId     String?
  instanceId String
  formTitle  String   @default("")
  data       String   @default("{}") // JSON
  createdAt  DateTime @default(now())

  @@index([siteId])
}

model Outbox {
  id        String   @id @default(cuid())
  to        String
  subject   String
  body      String
  kind      String
  meta      String   @default("{}")
  createdAt DateTime @default(now())
}

model Audit {
  id        String   @id @default(cuid())
  userId    String
  siteId    String?
  action    String
  data      String   @default("{}")
  createdAt DateTime @default(now())
}
